<Window x:Class="NetImage.Views.BootSectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Boot Sector Editor" Height="600" Width="740">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Boot Sector (512 bytes)" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="Offset 0x000 - 0x1FF" Foreground="Gray" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Hex editor grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <Grid Name="HexEditorGrid" Background="#0000AA">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Offset column and hex values -->
                <StackPanel Grid.Column="0" Name="OffsetAndHexPanel" Margin="5"/>

                <!-- ASCII column -->
                <StackPanel Grid.Column="1" Name="AsciiPanel" Margin="5"/>
            </Grid>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Load from file" Width="90" Click="LoadDataButton_Click" Margin="0,0,10,0"/>
            <Button Content="Save to file" Width="90" Click="SaveDataButton_Click" Margin="0,0,10,0"/>
            <Button Content="Save" Width="80" Click="SaveButton_Click" IsDefault="True" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
