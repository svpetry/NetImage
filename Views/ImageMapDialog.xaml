<Window x:Class="NetImage.Views.ImageMapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Map" Height="600" Width="900" MinWidth="600" MinHeight="400">
    <Window.Resources>
        <Style x:Key="LegendItemStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Disk Image Map" FontWeight="Bold" FontSize="14"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBlock Text="View:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <RadioButton Content="Sectors" GroupName="ViewMode" IsChecked="True" VerticalAlignment="Center" Checked="ViewMode_Checked"/>
                    <RadioButton Content="Clusters" GroupName="ViewMode" VerticalAlignment="Center" Margin="10,0,0,0" Checked="ViewMode_Checked"/>
                </StackPanel>
            </Grid>
            <TextBlock x:Name="InfoTextBlock" Text="" Foreground="Gray" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Sector visualization -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
            <Border BorderThickness="1" BorderBrush="#CCCCCC" Padding="10">
                <UniformGrid x:Name="SectorGrid"/>
            </Border>
        </ScrollViewer>

        <!-- Legend and Statistics -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Legend -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Legend:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border BorderThickness="1" BorderBrush="#EEEEEE" Background="#FAFAFA" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#4CAF50" Margin="0,0,8,0"/>
                                <TextBlock Text="Boot Sector" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#2196F3" Margin="0,0,8,0"/>
                                <TextBlock Text="Partition Table" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#FF9800" Margin="0,0,8,0"/>
                                <TextBlock Text="FAT" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#9C27B0" Margin="0,0,8,0"/>
                                <TextBlock Text="Root Directory" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#F44336" Margin="0,0,8,0"/>
                                <TextBlock Text="Allocated" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#9E9E9E" Margin="0,0,8,0"/>
                                <TextBlock Text="Free Space" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource LegendItemStyle}">
                                <Rectangle Width="16" Height="16" Fill="#607D8B" Margin="0,0,8,0"/>
                                <TextBlock Text="Reserved/Other" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Distribution Pie Chart -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Distribution:" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <Canvas x:Name="PieChartCanvas" Width="100" Height="100"/>
            </StackPanel>

            <!-- Statistics -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Statistics:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border BorderThickness="1" BorderBrush="#EEEEEE" Background="#FAFAFA" Padding="10">
                    <StackPanel>
                        <StackPanel Style="{StaticResource LegendItemStyle}">
                            <TextBlock Text="Total:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TotalSizeText" Text="-" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource LegendItemStyle}">
                            <TextBlock Text="Allocated:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="AllocatedText" Text="-" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource LegendItemStyle}">
                            <TextBlock Text="Free:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="FreeText" Text="-" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource LegendItemStyle}">
                            <TextBlock Text="Usage:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="UsageText" Text="-" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Close Button -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Width="90" Click="CloseButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
