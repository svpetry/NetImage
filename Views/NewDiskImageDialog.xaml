<Window x:Class="NetImage.Views.NewDiskImageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Disk Image" Height="250" Width="400"
        Icon="/diskette.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid x:Name="MainGrid" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select disk image format:" Grid.Row="0" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <RadioButton Content="160 KB (512 bytes/sector)" IsChecked="True" Tag="163840"/>
            <RadioButton Content="180 KB (512 bytes/sector)" Tag="184320"/>
            <RadioButton Content="320 KB (512 bytes/sector)" Tag="327680"/>
            <RadioButton Content="360 KB (512 bytes/sector)" Tag="368640"/>
            <RadioButton Content="720 KB (512 bytes/sector)" Tag="737280"/>
            <RadioButton Content="1.2 MB (512 bytes/sector)" Tag="1245184"/>
            <RadioButton Content="1.44 MB (512 bytes/sector)" Tag="1474560"/>
            <RadioButton Content="2.88 MB (512 bytes/sector)" Tag="3006476"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="75" Margin="0,0,10,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="75" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
