<Window x:Class="NetImage.Views.FileEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit File" Height="500" Width="800" MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F0F0F0">
            <MenuItem Header="_Find" Click="MenuFind_Click" InputGestureText="Ctrl+F"/>
            <MenuItem Command="Undo" CommandTarget="{Binding ElementName=EditTextBox}" Header="_Undo"/>
            <MenuItem Command="Redo" CommandTarget="{Binding ElementName=EditTextBox}" Header="_Redo"/>
        </Menu>
        
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- File info header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding FileName}" FontWeight="Bold" FontSize="14"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="{Binding FileSize, StringFormat='Size: {0:N0} bytes'}" Foreground="Gray"/>
                <TextBlock Text=" | " Foreground="Gray" Margin="10,0"/>
                <TextBlock Text="{Binding ModifiedTime, StringFormat='Modified: {0:g}'}" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <!-- Text area for editing -->
        <TextBox Grid.Row="1"
                 Name="EditTextBox"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Lucida Console"
                 FontSize="12"
                 Background="#0000AA"
                 Foreground="White"
                 SelectionBrush="White"
                 SelectionTextBrush="DarkSlateBlue"
                 Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Click="SaveButton_Click" IsDefault="True" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
        </Grid>
    </DockPanel>
</Window>
