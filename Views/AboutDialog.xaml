<Window x:Class="NetImage.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About NetImage" Height="185" Width="420"
        Icon="/diskette.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ApplicationNameTextBlock"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Margin="0,0,0,12">
            <Run Text="Version "/>
            <Run x:Name="VersionRun"/>
        </TextBlock>

        <TextBlock Grid.Row="2" TextWrapping="Wrap" Margin="0,0,0,16">
            <Run Text="GitHub repository: "/>
            <Hyperlink x:Name="RepositoryHyperlink" RequestNavigate="RepositoryHyperlink_RequestNavigate">
                <Run x:Name="RepositoryLinkRun"/>
            </Hyperlink>
        </TextBlock>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Width="75" Click="CloseButton_Click" IsCancel="True" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
